# Copy to .env.local

# Enable local planner UI + API
VITE_ENABLE_LOCAL_PLANNER=true

# Ollama (browser display + dev server middleware)
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama3.1:8b
VITE_OLLAMA_TIMEOUT_MS=20000
VITE_OLLAMA_TEMPERATURE=0

# Log raw Ollama responses and validation details to server console
# VITE_PLANNER_DEBUG=true

# Server-side fallbacks (optional — used if VITE_* not set in Node)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_MS=20000
ENABLE_LOCAL_PLANNER=true

# Standalone server: npm run dev:planner
PLANNER_PORT=8787
